---
import Layout from "../layout/Layout.astro";
const celtaLogo = "url(/assets/celta-escudo.svg)";

---

<Layout>
  <div class="dashboard">
    <header class="header">
      <div class="brand">
        <div class="brand-badge"></div>
        <div>
          <div class="brand-text-sub">Dashboard · Home</div>
          <div class="brand-text-main">RC Celta · Clasificación</div>
        </div>
      </div>
      <div class="header-right">
        <div class="pill">
          <span class="pill-dot"></span>
          <span id="season-pill">Temporada</span>
        </div>
        <div class="updated" id="updated-label">Actualizando…</div>
      </div>
    </header>

    <main class="content">
      <section class="summary">
        <div class="summary-main">
          Situación actual del <span>RC Celta</span> en LALIGA EA SPORTS.
        </div>
        <div class="summary-highlight">
          <strong id="celta-pos">–</strong>
          <small>posición Celta</small>
        </div>
      </section>

      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th class="team-col">Equipo</th>
              <th>PJ</th>
              <th>G</th>
              <th>E</th>
              <th>P</th>
              <th>GF</th>
              <th>GC</th>
              <th>DG</th>
              <th>PTS</th>
            </tr>
          </thead>
          <tbody id="table-body">
            <!-- filas generadas por JS -->
          </tbody>
        </table>
      </div>

      <div class="footer">
        <span><span class="legend-dot"></span> Fila destacada: RC Celta</span>
        <span id="footer-competition">LALIGA EA SPORTS · Datos locales</span>
      </div>

      <div class="error-message" id="error-message" style="display:none;"></div>
    </main>
  </div>

<script src="../lib/script.js"></script>
</Layout>

  <style is:global define:vars={{ celtaLogo }}>
    :root {
      --celta-blue: #8ac3ee;
      --celta-red: #e5254e;
      --celta-gold: #b19221;
      --bg-dark: #0b1720;
      --bg-card: #111f2a;
      --text-main: #f5f8fc;
      --text-soft: #a7b7c7;
      --border-soft: rgba(255,255,255,0.08);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: radial-gradient(circle at top, #14283a 0, #050b10 55%, #020509 100%);
      color: var(--text-main);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 16px;
    }

    .dashboard {
      width: 100%;
      max-width: 900px;
      background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.005));
      border-radius: 24px;
      border: 1px solid rgba(255,255,255,0.08);
      box-shadow:
        0 24px 60px rgba(0,0,0,0.7),
        0 0 0 1px rgba(0,0,0,0.6);
      overflow: hidden;
      backdrop-filter: blur(14px);
    }

    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 22px;
      background: linear-gradient(135deg, rgba(138,195,238,0.16), rgba(11,23,32,0.9));
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .brand-badge {
      width: 32px;
      height: 48px;
      border-radius: 18px;
      background:
        linear-gradient(160deg, var(--celta-blue), #d3ecfb);
      position: relative;
      box-shadow:
        0 0 0 2px rgba(255,255,255,0.65),
        0 10px 22px rgba(0,0,0,0.45);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .brand-badge::after {
      content: var(--celtaLogo);
      position: absolute;
      top: 0px;
      left: 2px;
      width: 12px;
      height: 12px;
      border-radius: 50% 50% 2px 2px;
    }

    .brand-text-main {
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: 0.09em;
      text-transform: uppercase;
    }

    .brand-text-sub {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: var(--text-soft);
    }

    .header-right {
      text-align: right;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 5px 10px;
      border-radius: 999px;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      border: 1px solid rgba(255,255,255,0.18);
      background: rgba(5,11,16,0.6);
      color: var(--text-soft);
    }

    .pill-dot {
      width: 6px;
      height: 6px;
      border-radius: 999px;
      background: #3ee98b;
      box-shadow: 0 0 0 4px rgba(62,233,139,0.22);
    }

    .updated {
      margin-top: 4px;
      font-size: 0.7rem;
      color: var(--text-soft);
    }

    .content {
      padding: 14px 18px 18px;
      background: var(--bg-dark);
    }

    .summary {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 14px;
      gap: 12px;
      flex-wrap: wrap;
    }

    .summary-main {
      font-size: 0.95rem;
      color: var(--text-soft);
    }

    .summary-main span {
      color: var(--celta-blue);
      font-weight: 600;
    }

    .summary-highlight {
      display: flex;
      align-items: baseline;
      gap: 6px;
      font-size: 0.9rem;
    }

    .summary-highlight strong {
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--celta-gold);
    }

    .summary-highlight small {
      color: var(--text-soft);
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

/*     .table-wrapper {
      border-radius: 18px;
      background: var(--bg-card);
      border: 1px solid var(--border-soft);
      overflow: hidden;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.82rem;
    } */

.table-wrapper {
  border-radius: 18px;
  background: var(--bg-card);
  border: 1px solid var(--border-soft);
  overflow-x: auto;     /* scroll horizontal */
  overflow-y: hidden;
}

/* Para que el sticky funcione bien */
table {
  border-collapse: collapse;
  font-size: 0.82rem;
  min-width: 700px;     /* obliga a hacer scroll en pantallas estrechas */
}

/* Primera columna (#) fija */
th:nth-child(1),
td:nth-child(1) {
  position: sticky;
  left: 0;
  z-index: 3;
  background: var(--bg-card);
}

/* Segunda columna (Equipo) fija, pegada a la primera */
th:nth-child(2),
td:nth-child(2) {
  position: sticky;
  left: 60px;           /* ajusta este valor al ancho real de la primera col */
  z-index: 3;
  background: var(--bg-card);
}

/* Un poco más de z-index para el header */
thead th:nth-child(1),
thead th:nth-child(2) {
  z-index: 4;
}

    thead {
      background: linear-gradient(90deg, rgba(138,195,238,0.18), rgba(138,195,238,0.02));
      border-bottom: 1px solid var(--border-soft);
    }

    th,
    td {
      padding: 8px 10px;
      text-align: center;
      white-space: nowrap;
    }

    th {
      font-weight: 600;
      text-transform: uppercase;
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      color: var(--text-soft);
    }

    th.team-col,
    td.team-col {
      text-align: left;
    }

    tbody tr {
      border-top: 1px solid rgba(255,255,255,0.04);
      transition: background 140ms ease-out, transform 90ms ease-out;
    }

    tbody tr:nth-child(2n) {
      background: rgba(255,255,255,0.01);
    }

    tbody tr:hover {
      background: rgba(138,195,238,0.06);
      transform: translateY(-1px);
    }

    .pos {
      font-variant-numeric: tabular-nums;
      color: var(--text-soft);
    }

    .pos-top4 {
      color: var(--celta-gold);
    }

    .team-name {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .team-dot {
      width: 18px;
      height: 18px;
      border-radius: 999px;
      background: radial-gradient(circle at 30% 20%, #ffffff, var(--celta-blue));
      box-shadow:
        0 0 0 1px rgba(255,255,255,0.6),
        0 4px 8px rgba(0,0,0,0.5);
    }

    .team-name span {
      font-weight: 500;
    }

    .team-name.celta span {
      color: var(--celta-blue);
      text-shadow: 0 0 12px rgba(138,195,238,0.7);
    }

    .badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 2px 6px;
      border-radius: 999px;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      border: 1px solid rgba(255,255,255,0.28);
    }

    .badge-celta {
      border-color: rgba(138,195,238,0.8);
      color: var(--celta-blue);
      background: rgba(138,195,238,0.1);
    }

    .trend-pos {
      font-variant-numeric: tabular-nums;
    }

    .trend-up {
      color: #3ee98b;
    }

    .trend-down {
      color: #ff7f5f;
    }

    .footer {
      margin-top: 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.7rem;
      color: var(--text-soft);
      opacity: 0.86;
    }

    .footer span {
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      border: 2px solid var(--celta-blue);
      box-shadow: 0 0 8px rgba(138,195,238,0.7);
    }

    .error-message {
      margin-top: 12px;
      font-size: 0.8rem;
      color: #ff7f5f;
    }

    @media (max-width: 640px) {
      .dashboard {
        border-radius: 18px;
      }
      .header {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
      }
      .summary {
        flex-direction: column;
        align-items: flex-start;
      }
      th:nth-child(6),
      td:nth-child(6),
      th:nth-child(7),
      td:nth-child(7) {
        display: none;
      }
    }
  </style>